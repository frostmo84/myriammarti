---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Myriam Marti — Fotograf Oslo/Lillestrøm">

  <!-- HERO -->
  <section class="relative w-full overflow-hidden">
    
    <!-- Tekst overlay — nederst til venstre med god margin -->
    <div class="absolute bottom-10 left-12 z-10">
      <p class="text-2xl leading-tight font-light"
         style="font-family: 'Playfair Display', serif; color: white; text-shadow: 0 2px 8px rgba(0,0,0,0.5); letter-spacing: 0.06em; line-height: 1.15;">
        MYRIAM<br/>MARTI
      </p>
      <span class="inline-block mt-2 px-3 py-1 text-xs tracking-widest uppercase"
            style="background-color: var(--color-gold); color: white; letter-spacing: 0.18em;">
        FOTOGRAFI
      </span>
    </div>

    <!-- Hero-bilde -->
    <img
      src={`${base}images/hero.jpg`}
      alt="Myriam Marti Fotografi — gravid og nyfødt"
      class="w-full object-cover"
      style="height: 88vh; object-position: center center;"
    />
  </section>

  <!-- INTRO-TEKST -->
  <section class="max-w-3xl mx-auto px-6 py-20 text-center">
    <p class="text-xs tracking-widest uppercase mb-4" style="color: var(--color-gold);">Fotograf i Oslo og Lillestrøm</p>
    <h1 class="text-4xl mb-6" style="font-family: 'Playfair Display', serif;">
      Øyeblikk du aldri vil glemme
    </h1>
    <p class="text-lg mb-10" style="color: var(--color-muted); line-height: 1.8;">
      Jeg fotograferer gravide, nyfødte og familier — med varme, ro og et blikk for det ekte. 
      Velkommen til et trygt og avslappet fotoatelier på Fetsund.
    </p>
    <a href="/myriammarti/kontakt"
       class="inline-block px-8 py-4 rounded-full text-sm tracking-wide hover:opacity-80 transition"
       style="background-color: var(--color-gold); color: white; letter-spacing: 0.08em;">
      Book gratis konsultasjon
    </a>
  </section>

  <!-- TJENESTER -->
  <section class="py-16" style="background-color: var(--color-surface);">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl text-center mb-3" style="font-family: 'Playfair Display', serif;">Hva jeg fotograferer</h2>
      <p class="text-center text-sm mb-12" style="color: var(--color-muted);">Velg den tjenesten som passer deg</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/myriammarti/gravid"
           class="rounded-2xl overflow-hidden hover:shadow-lg transition"
           style="background-color: var(--color-bg);">
          <img src={`${base}images/gravid.png`} alt="Gravidfotografering"
               class="w-full object-cover" style="height: 280px; object-position: center top;" />
          <div class="p-6">
            <p class="text-xs tracking-widest uppercase mb-2" style="color: var(--color-gold);">Gravid</p>
            <h3 class="text-xl mb-1" style="font-family: 'Playfair Display', serif;">Gravidfotografering</h3>
            <p class="text-sm" style="color: var(--color-muted);">En vakker sesjon som feirer den ventende magen.</p>
          </div>
        </a>

        <a href="/myriammarti/nyfoedt"
           class="rounded-2xl overflow-hidden hover:shadow-lg transition"
           style="background-color: var(--color-bg);">
          <div class="flex items-center justify-center" style="height: 280px; background-color: var(--color-border);">
            <p style="color: var(--color-muted); font-size: 0.85rem;">Bilde kommer</p>
          </div>
          <div class="p-6">
            <p class="text-xs tracking-widest uppercase mb-2" style="color: var(--color-gold);">Nyfødt</p>
            <h3 class="text-xl mb-1" style="font-family: 'Playfair Display', serif;">Nyfødtfotografering</h3>
            <p class="text-sm" style="color: var(--color-muted);">De første dagene — fanget for alltid.</p>
          </div>
        </a>

        <a href="/myriammarti/familie"
           class="rounded-2xl overflow-hidden hover:shadow-lg transition"
           style="background-color: var(--color-bg);">
          <div class="flex items-center justify-center" style="height: 280px; background-color: var(--color-border);">
            <p style="color: var(--color-muted); font-size: 0.85rem;">Bilde kommer</p>
          </div>
          <div class="p-6">
            <p class="text-xs tracking-widest uppercase mb-2" style="color: var(--color-gold);">Familie</p>
            <h3 class="text-xl mb-1" style="font-family: 'Playfair Display', serif;">Familiefotografering</h3>
            <p class="text-sm" style="color: var(--color-muted);">Naturlige øyeblikk med de du er glad i.</p>
          </div>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>
