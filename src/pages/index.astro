---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Myriam Marti — Fotograf Oslo/Lillestrøm">

  <!-- HERO -->
  <section class="max-w-5xl mx-auto px-6 py-28 text-center">
    <p class="text-sm tracking-widest uppercase mb-4" style="color: var(--color-gold);">Fotograf i Oslo og Lillestrøm</p>
    <h1 class="text-5xl mb-6" style="font-family: 'Playfair Display', serif; color: var(--color-text);">
      Øyeblikk du aldri<br />vil glemme
    </h1>
    <p class="text-lg mb-10 max-w-xl mx-auto" style="color: var(--color-muted);">
      Jeg fotograferer gravide, nyfødte og familier — med varme, ro og et blikk for det ekte.
    </p>
    <a href="/myriammarti/kontakt"
       class="inline-block px-8 py-4 rounded-full text-sm tracking-wide hover:opacity-80 transition"
       style="background-color: var(--color-gold); color: white; letter-spacing: 0.08em;">
      Book gratis konsultasjon
    </a>
  </section>

  <!-- TJENESTER -->
  <section class="py-20" style="background-color: var(--color-surface);">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl text-center mb-3" style="font-family: 'Playfair Display', serif;">Hva jeg fotograferer</h2>
      <p class="text-center text-sm mb-12" style="color: var(--color-muted);">Velg den tjenesten som passer deg</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <a href="/myriammarti/gravid"
           class="p-8 rounded-2xl hover:shadow-md transition"
           style="background-color: var(--color-bg);">
          <p class="text-xs tracking-widest uppercase mb-3" style="color: var(--color-gold);">Gravid</p>
          <h3 class="text-xl mb-2" style="font-family: 'Playfair Display', serif;">Gravidfotografering</h3>
          <p class="text-sm" style="color: var(--color-muted);">En vakker sesjon som feirer den ventende magen.</p>
        </a>

        <a href="/myriammarti/nyfoedt"
           class="p-8 rounded-2xl hover:shadow-md transition"
           style="background-color: var(--color-bg);">
          <p class="text-xs tracking-widest uppercase mb-3" style="color: var(--color-gold);">Nyfødt</p>
          <h3 class="text-xl mb-2" style="font-family: 'Playfair Display', serif;">Nyfødtfotografering</h3>
          <p class="text-sm" style="color: var(--color-muted);">De første dagene — fanget for alltid.</p>
        </a>

        <a href="/myriammarti/familie"
           class="p-8 rounded-2xl hover:shadow-md transition"
           style="background-color: var(--color-bg);">
          <p class="text-xs tracking-widest uppercase mb-3" style="color: var(--color-gold);">Familie</p>
          <h3 class="text-xl mb-2" style="font-family: 'Playfair Display', serif;">Familiefotografering</h3>
          <p class="text-sm" style="color: var(--color-muted);">Naturlige øyeblikk med de du er glad i.</p>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>
