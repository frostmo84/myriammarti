---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Myriam Marti — Fotograf Oslo/Lillestrøm">

  <!-- HERO -->
  <section class="max-w-5xl mx-auto px-6 py-24 text-center">
    <h1 class="text-5xl font-bold tracking-tight mb-6">
      Fotograf i Oslo og Lillestrøm
    </h1>
    <p class="text-xl text-gray-600 mb-10 max-w-2xl mx-auto">
      Jeg fotograferer gravide, nyfødte og familier — og hjelper deg å bevare 
      de øyeblikkene du aldri vil glemme.
    </p>
    <a href="/myriammarti/kontakt"
       class="bg-gray-900 text-white px-8 py-4 rounded-full text-lg hover:bg-gray-700 transition">
      Book gratis konsultasjon
    </a>
  </section>

  <!-- TJENESTER -->
  <section class="bg-gray-50 py-20">
    <div class="max-w-5xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Hva jeg fotograferer</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

        <a href="/myriammarti/gravid" class="bg-white p-8 rounded-2xl hover:shadow-md transition">
          <h3 class="text-xl font-semibold mb-2">Gravidfotografering</h3>
          <p class="text-gray-600 text-sm">En vakker sesjon som feirer den ventende magen.</p>
        </a>

        <a href="/myriammarti/nyfoedt" class="bg-white p-8 rounded-2xl hover:shadow-md transition">
          <h3 class="text-xl font-semibold mb-2">Nyfødtfotografering</h3>
          <p class="text-gray-600 text-sm">De første dagene — fanget for alltid.</p>
        </a>

        <a href="/myriammarti/familie" class="bg-white p-8 rounded-2xl hover:shadow-md transition">
          <h3 class="text-xl font-semibold mb-2">Familiefotografering</h3>
          <p class="text-gray-600 text-sm">Naturlige øyeblikk med de du er glad i.</p>
        </a>

      </div>
    </div>
  </section>

</BaseLayout>